generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  EMPRESA
  CAPTADOR
  STAFF
}

enum CampaignStatus {
  ACTIVE
  PAUSED
  ENDED
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  NO_SHOW
}

enum TransactionType {
  CREDIT
  DEBIT
}

enum BonoRedemptionStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  passwordHash    String
  name            String
  role            Role      @default(CAPTADOR)
  phone           String?
  language        String    @default("es")
  stripeAccountId String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  business     Business?
  reservations Reservation[] @relation("CaptadorReservations")
  staffScans   StaffScan[]
  wallet       Wallet?
}

model Business {
  id          String   @id @default(cuid())
  name        String
  type        String
  description String?
  address     String?
  logoUrl     String?
  userId      String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaigns Campaign[]
  staff     BusinessStaff[]
}

model BusinessStaff {
  id         String   @id @default(cuid())
  businessId String
  email      String
  name       String
  pin        String?  @unique // 4-digit unique PIN for QR validation
  createdAt  DateTime @default(now())

  business   Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  staffScans StaffScan[]
}

model Campaign {
  id               String         @id @default(cuid())
  title            String
  description      String?
  businessId       String
  incentiveTypes   String[]
  incentiveValue   Float    @default(0)   // legacy: shared value, kept for backward compat
  fixedValue       Float?                  // € per reservation when FIXED is chosen
  percentageValue  Float?                  // % of ticket when PERCENTAGE is chosen
  bonusDescription String?
  bonusMinValue    Float?          // min wallet balance required to redeem this bono
  status           CampaignStatus @default(ACTIVE)
  startDate        DateTime
  endDate          DateTime?
  maxReservations  Int?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  business         Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  reservations     Reservation[]
  bonoRedemptions  BonoRedemption[]
}

model Reservation {
  id            String            @id @default(cuid())
  campaignId    String
  captadorId    String
  clientName    String
  clientEmail   String
  clientPhone   String
  date          DateTime
  time          String
  guests        Int
  notes         String?
  qrToken       String            @unique @default(cuid())
  qrScannedAt   DateTime?
  status        ReservationStatus @default(PENDING)
  incentivePaid Boolean           @default(false)
  chosenIncentiveType String?     // "FIXED" | "PERCENTAGE" | "BONO" picked by the captador
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  campaign    Campaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  captador    User        @relation("CaptadorReservations", fields: [captadorId], references: [id])
  staffScan   StaffScan?
  transaction Transaction?
}

model StaffScan {
  id              String   @id @default(cuid())
  reservationId   String   @unique
  staffId         String?  // legacy: User.id (kept for backward compat)
  businessStaffId String?  // PIN-based flow: BusinessStaff.id
  scannedAt       DateTime @default(now())

  reservation   Reservation    @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  staff         User?          @relation(fields: [staffId], references: [id])
  businessStaff BusinessStaff? @relation(fields: [businessStaffId], references: [id])
}

model Wallet {
  id        String        @id @default(cuid())
  userId    String        @unique
  balance   Float         @default(0)
  updatedAt DateTime      @updatedAt

  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions     Transaction[]
  bonoRedemptions  BonoRedemption[]
}

model Transaction {
  id            String          @id @default(cuid())
  walletId      String
  amount        Float
  type          TransactionType
  description   String
  reservationId String?         @unique
  createdAt     DateTime        @default(now())

  wallet      Wallet       @relation(fields: [walletId], references: [id], onDelete: Cascade)
  reservation Reservation? @relation(fields: [reservationId], references: [id])
}

model BonoRedemption {
  id         String               @id @default(cuid())
  walletId   String
  campaignId String
  amount     Float                // wallet balance deducted
  status     BonoRedemptionStatus @default(PENDING)
  notes      String?              // empresa notes on approval/rejection
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  wallet   Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
  campaign Campaign @relation(fields: [campaignId], references: [id])
}
