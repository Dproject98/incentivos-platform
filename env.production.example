# ─────────────────────────────────────────────────────────────
# incentivos-app — Variables de entorno para producción
# Copia este archivo como .env.production y rellena los valores
# ─────────────────────────────────────────────────────────────

# PostgreSQL (local Docker)
# Cambia esta contraseña por una fuerte y única
POSTGRES_PASSWORD=TU_PASSWORD_SEGURA

# NextAuth
# Genera con: openssl rand -base64 32
NEXTAUTH_SECRET=TU_NEXTAUTH_SECRET_AQUI
NEXTAUTH_URL=https://tudominio.com

# Resend — emails transaccionales
# Crea una cuenta en resend.com (gratis hasta 3.000 emails/mes)
RESEND_API_KEY=TU_RESEND_API_KEY

# Twilio WhatsApp — notificaciones WhatsApp (opcional)
# Deja vacío si no quieres activar WhatsApp
TWILIO_ACCOUNT_SID=TU_TWILIO_ACCOUNT_SID
TWILIO_AUTH_TOKEN=TU_TWILIO_AUTH_TOKEN
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Stripe — pagos y transferencias a captadores
# Usa claves LIVE para producción (no test)
# Obtén tus claves en dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=TU_STRIPE_SECRET_KEY_LIVE
STRIPE_WEBHOOK_SECRET=TU_STRIPE_WEBHOOK_SECRET
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=TU_STRIPE_PUBLISHABLE_KEY_LIVE
